---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import { ArrowRight, Calendar, User } from '@lucide/astro';

const posts = await getCollection('blog');
const sortedPosts = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const pageTitle = "Geometry & Measurement Guides | Blog";
const pageDescription = "Explore our step-by-step guides on roof pitch, woodworking joints, compound miter cuts, and digital angle measurements.";
const pageKeywords = "geometry guides, roof pitch articles, woodworking measurement tips, angle finder tutorials";
---

<Layout title={pageTitle} description={pageDescription} keywords={pageKeywords}>
  <section class="py-16 md:py-24 bg-canvas-soft">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      
      <!-- Page Header -->
      <div class="text-center max-w-2xl mx-auto mb-16">
        <span class="font-mono text-xs font-semibold uppercase tracking-wider text-link bg-link-bg-soft px-3 py-1 rounded-full">
          Resources
        </span>
        <h1 class="mt-4 font-sans text-4xl font-semibold tracking-[-1.8px] text-ink sm:text-5xl leading-tight">
          Educational Guides & Insights.
        </h1>
        <p class="mt-3 font-sans text-base text-body">
          Learn how to measure angles, solve woodworking calculations, find roof pitch, and understand geometry basics.
        </p>
      </div>

      <!-- Blog Posts Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {sortedPosts.map((post) => (
          <article class="bg-white border border-hairline rounded-2xl p-6 shadow-vercel-3 flex flex-col justify-between hover:shadow-vercel-4 hover:border-hairline-strong/50 transition-all duration-200 group">
            <div>
              <!-- Meta Row -->
              <div class="flex items-center gap-3.5 text-xs text-mute font-mono mb-4">
                <span class="flex items-center gap-1">
                  <Calendar class="h-3.5 w-3.5" />
                  {post.data.pubDate.toLocaleDateString('en-US', {
                    month: 'short',
                    day: 'numeric',
                    year: 'numeric'
                  })}
                </span>
                <span class="h-3 w-px bg-hairline"></span>
                <span class="flex items-center gap-1">
                  <User class="h-3.5 w-3.5" />
                  {post.data.author}
                </span>
              </div>

              <!-- Title & Description -->
              <h2 class="font-sans text-lg font-semibold tracking-[-0.5px] text-ink group-hover:text-link transition duration-150 leading-snug">
                <a href={`/blog/${post.id}`}>
                  {post.data.title}
                </a>
              </h2>
              
              <p class="mt-3 font-sans text-sm text-body leading-relaxed line-clamp-3">
                {post.data.description}
              </p>

              <!-- Tags -->
              <div class="flex flex-wrap gap-1.5 mt-4">
                {post.data.tags.map((tag) => (
                  <span class="font-mono text-[9px] uppercase tracking-wider text-body bg-canvas-soft-2 px-2 py-0.5 rounded-full">
                    {tag}
                  </span>
                ))}
              </div>
            </div>

            <!-- Read Link -->
            <div class="mt-6 pt-4 border-t border-hairline">
              <a
                href={`/blog/${post.id}`}
                class="inline-flex items-center gap-1.5 font-sans text-xs font-semibold text-link group-hover:underline"
              >
                Read Article
                <ArrowRight class="h-3.5 w-3.5 transition group-hover:translate-x-0.5" />
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</Layout>
