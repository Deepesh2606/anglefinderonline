---
import Layout from '../layouts/Layout.astro';
import ImageAngleFinder from '../components/ImageAngleFinder.astro';
import { Compass, Table, Sliders, Info, ShieldAlert } from '@lucide/astro';

const pageTitle = "Roof Pitch Calculator & Angle Finder | Measure Roof Slope";
const pageDescription = "Calculate roof pitch from photos or angles. Convert pitch (rise over run) to degrees instantly. Includes a standard roof pitch chart and interactive diagram tool.";
const pageKeywords = "measure roof pitch angle from photo, roof pitch calculator, roof slope finder, convert roof angle to pitch, roof pitch chart";

const chartPitches = [
  { pitch: "1:12", degree: "4.76°", slope: "Low", multiplier: "1.008" },
  { pitch: "2:12", degree: "9.46°", slope: "Low", multiplier: "1.014" },
  { pitch: "3:12", degree: "14.04°", slope: "Low", multiplier: "1.031" },
  { pitch: "4:12", degree: "18.43°", slope: "Medium", multiplier: "1.054" },
  { pitch: "5:12", degree: "22.62°", slope: "Medium", multiplier: "1.083" },
  { pitch: "6:12", degree: "26.57°", slope: "Medium", multiplier: "1.118" },
  { pitch: "7:12", degree: "30.26°", slope: "Medium", multiplier: "1.158" },
  { pitch: "8:12", degree: "33.69°", slope: "Medium", multiplier: "1.202" },
  { pitch: "9:12", degree: "36.87°", slope: "Steep", multiplier: "1.250" },
  { pitch: "10:12", degree: "39.81°", slope: "Steep", multiplier: "1.302" },
  { pitch: "12:12", degree: "45.00°", slope: "Steep", multiplier: "1.414" },
];

const schemaMarkup = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Roof Pitch Calculator & Angle Finder",
  "description": "Calculate roof pitch from angles and photos. Bidirectional converter for rise over run (X:12) to degrees.",
  "mainEntity": {
    "@type": "SoftwareApplication",
    "name": "Roof Pitch Calculator",
    "operatingSystem": "All",
    "applicationCategory": "CalculatorApplication",
    "offers": {
      "@type": "Offer",
      "price": "0.00",
      "priceCurrency": "USD"
    }
  }
};
---

<Layout 
  title={pageTitle} 
  description={pageDescription} 
  keywords={pageKeywords} 
  schemaMarkup={schemaMarkup}
  image="https://anglefinderonline.com/og-image.png"
>
  <!-- Hero / Header -->
  <section class="py-12 bg-canvas-soft">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center mb-8">
      <span class="font-mono text-xs font-semibold uppercase tracking-wider text-link bg-link-bg-soft px-3 py-1 rounded-full">
        Roofer & Contractor Tools
      </span>
      <h1 class="mt-4 font-sans text-4xl font-semibold tracking-[-1.5px] text-ink sm:text-5xl leading-tight">
        Roof Pitch Calculator
      </h1>
      <p class="mt-3 mx-auto max-w-2xl font-sans text-base text-body">
        Convert between roof pitch ratio (rise over run) and degrees, or upload a photo to measure roof pitch directly.
      </p>
    </div>

    <!-- Bidirectional Converter Tool -->
    <div class="mx-auto max-w-3xl px-4 mb-12">
      <div class="bg-white border border-hairline rounded-xl p-6 md:p-8 shadow-vercel-3">
        <h2 class="font-sans text-xl font-semibold tracking-[-0.5px] text-ink mb-6 flex items-center gap-2">
          <Compass class="h-5 w-5 text-link" />
          Bidirectional Pitch Converter
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 items-center">
          <!-- Rise Input -->
          <div class="flex flex-col gap-2">
            <label for="pitch-rise" class="font-sans text-xs font-semibold text-body uppercase tracking-wider">
              Roof Pitch (Rise in inches)
            </label>
            <div class="flex items-center gap-2">
              <input
                type="number"
                id="pitch-rise"
                min="0.5"
                max="24"
                step="0.1"
                value="4"
                class="w-full border border-hairline rounded-lg h-12 px-4 font-sans text-base text-ink focus:outline-none focus:border-primary shadow-vercel-1"
              />
              <span class="font-sans text-base font-semibold text-mute shrink-0">/ 12 Pitch</span>
            </div>
            <span class="font-sans text-[11px] text-mute">Inches of vertical rise per 12 inches of horizontal run.</span>
          </div>

          <!-- Angle Input -->
          <div class="flex flex-col gap-2">
            <label for="pitch-angle" class="font-sans text-xs font-semibold text-body uppercase tracking-wider">
              Slope Angle (Degrees)
            </label>
            <div class="flex items-center gap-2">
              <input
                type="number"
                id="pitch-angle"
                min="2.3"
                max="63.4"
                step="0.01"
                value="18.43"
                class="w-full border border-hairline rounded-lg h-12 px-4 font-sans text-base text-ink focus:outline-none focus:border-primary shadow-vercel-1"
              />
              <span class="font-sans text-base font-semibold text-mute shrink-0">° Degrees</span>
            </div>
            <span class="font-sans text-[11px] text-mute">The incline of the roof measured from horizontal level.</span>
          </div>
        </div>

        <!-- Calculated Readouts -->
        <div class="mt-8 pt-6 border-t border-hairline grid grid-cols-2 sm:grid-cols-3 gap-6 bg-canvas-soft p-4 rounded-xl">
          <div class="flex flex-col">
            <span class="font-mono text-[9px] uppercase tracking-wider text-mute">Slope Category</span>
            <span id="pitch-category" class="font-sans text-base font-semibold text-ink mt-0.5">Medium Slope</span>
          </div>
          <div class="flex flex-col">
            <span class="font-mono text-[9px] uppercase tracking-wider text-mute">Rafter Length Factor</span>
            <span id="pitch-factor" class="font-sans text-base font-semibold text-ink mt-0.5">1.054</span>
          </div>
          <div class="flex flex-col col-span-2 sm:col-span-1">
            <span class="font-mono text-[9px] uppercase tracking-wider text-mute">E.g., 20ft Run Rafter</span>
            <span id="pitch-rafter-len" class="font-sans text-base font-semibold text-link mt-0.5">21.08 ft</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Photo Roof Measurement Tool -->
    <div class="mx-auto max-w-7xl px-4 mb-16">
      <div class="text-center mb-8">
        <h2 class="font-sans text-2xl font-semibold tracking-[-0.8px] text-ink">
          Measure Pitch Directly From Roof Photograph
        </h2>
        <p class="mt-2 text-sm text-body max-w-xl mx-auto">
          Upload a clear side-profile photo of your house or project, and adjust the protractor handles to find the pitch.
        </p>
      </div>

      <ImageAngleFinder client:visible />
      
      <!-- Specialized Help for Roof Pitch -->
      <div class="mx-auto max-w-3xl mt-4 bg-canvas-soft border border-hairline rounded-xl p-4 flex gap-3">
        <Info class="h-4 w-4 shrink-0 text-mute mt-0.5" />
        <div class="flex flex-col gap-1 text-left">
          <h4 class="font-sans text-xs font-semibold text-ink">How to measure roof pitch from a photo:</h4>
          <p class="font-sans text-[11.5px] text-body leading-relaxed">
            1. Drag the black handle <strong class="text-ink">V</strong> to the peak (ridge) of the roof.
            2. Place handle <strong class="text-ink">A</strong> horizontally along the roof baseline (eaves or window lines).
            3. Place handle <strong class="text-ink">B</strong> along the sloped rafter line.
            4. The calculated angle represents the slope in degrees. Input it into the converter above to get the pitch ratio (e.g. 4/12) instantly.
          </p>
        </div>
      </div>
    </div>

    <!-- Roof Pitch Chart -->
    <div id="chart" class="mx-auto max-w-4xl px-4 py-12">
      <div class="bg-white border border-hairline rounded-xl p-6 md:p-8 shadow-vercel-2">
        <h2 class="font-sans text-xl font-semibold tracking-[-0.5px] text-ink mb-6 flex items-center gap-2">
          <Table class="h-5 w-5 text-link" />
          Standard Roof Pitch Conversion Chart
        </h2>
        <p class="font-sans text-sm text-body mb-6">
          This reference table maps standard US roof pitches (inches of rise per 12 inches of run) to the corresponding slope angle in degrees and rafters multipliers.
        </p>

        <div class="overflow-x-auto">
          <table class="w-full text-left font-sans text-sm divide-y divide-hairline">
            <thead class="bg-canvas-soft-2 font-mono text-[10px] text-mute uppercase tracking-wider">
              <tr>
                <th class="px-4 py-3 font-semibold">Pitch (Rise:12)</th>
                <th class="px-4 py-3 font-semibold">Slope Angle (Degrees)</th>
                <th class="px-4 py-3 font-semibold">Classification</th>
                <th class="px-4 py-3 font-semibold text-right">Rafter Multiplier</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-hairline">
              {chartPitches.map((row) => (
                <tr class="hover:bg-canvas-soft transition-colors">
                  <td class="px-4 py-3.5 font-semibold text-ink">{row.pitch}</td>
                  <td class="px-4 py-3.5 text-body">{row.degree}</td>
                  <td class="px-4 py-3.5">
                    <span class={`inline-flex items-center rounded-md px-2 py-0.5 text-xs font-medium ${
                      row.slope === 'Low' ? 'bg-neutral-100 text-neutral-800' :
                      row.slope === 'Medium' ? 'bg-blue-50 text-blue-700' :
                      'bg-rose-50 text-rose-700'
                    }`}>
                      {row.slope}
                    </span>
                  </td>
                  <td class="px-4 py-3.5 text-right font-mono text-xs text-body">{row.multiplier}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        
        <div class="mt-6 border-t border-hairline pt-6 flex items-start gap-3 bg-rose-50/50 p-4 rounded-lg border border-rose-100">
          <ShieldAlert class="h-5 w-5 text-rose-600 shrink-0 mt-0.5" />
          <div class="text-left">
            <h4 class="font-sans text-xs font-semibold text-rose-900">Safety Disclaimer:</h4>
            <p class="font-sans text-xs text-rose-700 leading-relaxed mt-0.5">
              Measuring pitch directly on the roof using mechanical gauges can be hazardous. We strongly recommend taking a clean photo of your building roof from ground level and using this online photo angle tool to calculate pitch configurations safely.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  // Live Converter calculations
  const riseInput = document.getElementById('pitch-rise') as HTMLInputElement;
  const angleInput = document.getElementById('pitch-angle') as HTMLInputElement;
  const categoryDisplay = document.getElementById('pitch-category');
  const factorDisplay = document.getElementById('pitch-factor');
  const rafterDisplay = document.getElementById('pitch-rafter-len');

  if (riseInput && angleInput) {
    riseInput.addEventListener('input', () => {
      const rise = parseFloat(riseInput.value);
      if (isNaN(rise) || rise <= 0) return;

      // Calculate angle in degrees
      const angle = Math.atan(rise / 12) * (180 / Math.PI);
      angleInput.value = angle.toFixed(2);
      
      updateDetails(rise, angle);
    });

    angleInput.addEventListener('input', () => {
      const angle = parseFloat(angleInput.value);
      if (isNaN(angle) || angle <= 0 || angle >= 90) return;

      // Calculate rise in inches
      const rise = 12 * Math.tan(angle * (Math.PI / 180));
      riseInput.value = rise.toFixed(2);

      updateDetails(rise, angle);
    });
  }

  function updateDetails(rise: number, angle: number) {
    // 1. Classification
    let classification = "Medium Slope";
    if (rise <= 3) classification = "Low Slope";
    else if (rise >= 9) classification = "Steep Slope";
    
    if (categoryDisplay) categoryDisplay.innerText = classification;

    // 2. Rafter multiplier
    const factor = Math.sqrt(1 + (rise * rise) / 144);
    if (factorDisplay) factorDisplay.innerText = factor.toFixed(3);

    // 3. Example rafter length (20ft horizontal run)
    const rafterLen = 20 * factor;
    if (rafterDisplay) rafterDisplay.innerText = rafterLen.toFixed(2) + ' ft';
  }
</script>
