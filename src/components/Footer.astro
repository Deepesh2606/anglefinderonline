---
const currentYear = new Date().getFullYear();

const footerSections = [
  {
    title: 'Tools',
    links: [
      { label: 'Image Angle Finder', href: '/tool/image' },
      { label: 'Webcam Angle Finder', href: '/tool/webcam' },
      { label: 'Roof Pitch Calculator', href: '/roof-pitch-calculator' },
      { label: 'Woodworking Angles', href: '/woodworking-angle-finder' },
    ],
  },
  {
    title: 'Resources',
    links: [
      { label: 'Printable Protractor', href: '/printable-protractor' },
      { label: 'How-to Guides', href: '/blog' },
      { label: 'Roof Pitch Chart', href: '/roof-pitch-calculator#chart' },
      { label: 'Miter Joint Reference', href: '/woodworking-angle-finder#miters' },
      { label: 'Pricing details', href: '/pricing' },
    ],
  },
  {
    title: 'Company',
    links: [
      { label: 'About Us', href: '/about' },
      { label: 'Contact Us', href: '/contact' },
    ],
  },
  {
    title: 'Legal',
    links: [
      { label: 'Privacy Policy', href: '/privacy' },
      { label: 'Terms & Conditions', href: '/terms' },
    ],
  },
];
---

<footer class="border-t border-hairline bg-gradient-to-b from-white to-[#fafafa]">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-12 sm:py-14 lg:py-16">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 lg:gap-10">
      <!-- Brand column -->
      <div class="space-y-4">
        <a href="/" class="flex items-center gap-2.5 group">
          <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-primary text-white transition-transform group-hover:scale-105 duration-300 ease-out">
            <svg class="h-4.5 w-4.5" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
              <title>Online Angle Finder Logo</title>
              <path d="M26 24L8 24L16 8" stroke="currentColor" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M12 24C12 21.7909 13.7909 20 16 20C18.2091 20 20 21.7909 20 24" stroke="currentColor" stroke-opacity="0.5" stroke-width="2.5" stroke-linecap="round"/>
            </svg>
          </div>
          <span class="font-sans text-base font-semibold tracking-[-0.3px] text-ink group-hover:text-[#0070f3] transition-colors duration-300">
            Online Angle Finder
          </span>
        </a>
        <p class="max-w-xs font-sans text-sm text-body leading-relaxed pr-4">
          Measure angles instantly from photos, diagrams, and live camera input. Ad-free, fast, and engineered for high precision.
        </p>
        <!-- Mock System Status Indicator (Vercel Style) -->
        <div class="flex items-center gap-2.5 pt-2">
          <span class="relative flex h-2 w-2">
            <span class="relative inline-flex h-2 w-2 rounded-full bg-emerald-500 animate-pulse"></span>
          </span>
          <span class="font-mono text-xs text-mute uppercase tracking-wide">
            All services operational
          </span>
        </div>
      </div>

      <!-- Links columns -->
      <div class="grid grid-cols-2 sm:grid-cols-2 md:grid-cols-4 gap-6 sm:gap-8 lg:col-span-2">
        {footerSections.map((section) => (
          <div class="min-w-0">
            <h3 class="font-mono text-[11px] font-semibold uppercase tracking-wider text-ink truncate">
              {section.title}
            </h3>
            <ul role="list" class="mt-3 sm:mt-4 space-y-2 sm:space-y-2.5">
              {section.links.map((link) => (
                <li>
                  <a href={link.href} class="font-sans text-[12px] sm:text-[13px] text-body hover:text-[#0070f3] transition-colors duration-300 ease-out break-words inline-block hover:translate-x-0.5 transform">
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>

    <!-- Divider -->
    <div class="mt-10 sm:mt-14 border-t border-hairline pt-6 sm:pt-8 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 sm:gap-4">
      <p class="font-sans text-xs text-mute">
        &copy; {currentYear} anglefinderonline.com. All rights reserved. Created in compliance with American Standards.
      </p>
      <div class="flex gap-3 sm:gap-4 flex-wrap">
        <a href="/privacy" class="font-sans text-xs text-mute hover:text-[#0070f3] transition-colors duration-300 whitespace-nowrap">Privacy Policy</a>
        <a href="/terms" class="font-sans text-xs text-mute hover:text-[#0070f3] transition-colors duration-300 whitespace-nowrap">Terms of Service</a>
      </div>
    </div>
  </div>
</footer>
